---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Accueil">

  <section class="hero">
    <span>👋 Bienvenue</span>

    <h1>Meriem Mehdi</h1>

    <p class="subtitle">
      Alternante en développement web chez <strong>Cliking</strong> ·
      Apprenante à <strong>Ada Tech School</strong>
    </p>

    <p>
      Je documente ici mon parcours en développement web, mes apprentissages,
      mes découvertes autour de l’IA, mes projets et mon évolution dans la tech.
    </p>

    <div class="buttons">
      <a href={`${import.meta.env.BASE_URL}about`}>À propos</a>
      <a href={`${import.meta.env.BASE_URL}parcours`}>Mon parcours</a>
      <a href={`${import.meta.env.BASE_URL}blog`}>Lire le blog</a>
    </div>
  </section>

  <section>
    <h2>Ce que je partage ici</h2>

    <div class="grid">
      <article>
        <h3>📚 Formation Ada</h3>
        <p>
          Ce que j’apprends chaque semaine, mes découvertes et mes difficultés.
        </p>
      </article>

      <article>
        <h3>💼 Alternance</h3>
        <p>
          Mon expérience chez Cliking et ce que j’apprends en entreprise.
        </p>
      </article>

      <article>
        <h3>🤖 IA & LLM</h3>
        <p>
          Découverte des LLM, Ollama, modèles locaux et outils d’IA.
        </p>
      </article>

      <article>
        <h3>🚀 Projets</h3>
        <p>
          Mes projets personnels et techniques au fil de ma progression.
        </p>
      </article>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    padding: 4rem 0;
  }

  h1 {
    font-size: 4rem;
    margin: 1rem 0;
  }

  .subtitle {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .buttons a {
    padding: 12px 18px;
    border-radius: 12px;
    border: 1px solid #ddd;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  article {
    padding: 1.5rem;
    border: 1px solid #ddd;
    border-radius: 16px;
  }
</style>